{
  "name": "code-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:ts": "tsx --test tests-ts/**/*.test.ts",
    "check:ts": "npm run typecheck && npm run test:ts",
    "start:ts": "tsx src/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
